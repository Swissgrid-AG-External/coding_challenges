set shell := ["bash", "-cu"]

function_dir := "function_app"
compose_file := "docker-compose.local.yml"

help:
  @just --list

install:
  cd {{function_dir}} && python3 -m pip install -r requirements.txt

local-up:
  docker compose -f {{compose_file}} up -d

local-down:
  docker compose -f {{compose_file}} down -v

init-storage: install local-up
  python3 -c "from azure.storage.blob import BlobServiceClient; connection_string='UseDevelopmentStorage=true'; container_name='api-results'; blob_service=BlobServiceClient.from_connection_string(connection_string); container_client=blob_service.get_container_client(container_name); (container_client.create_container() or print(f'Created container: {container_name}')) if not container_client.exists() else print(f'Container already exists: {container_name}')"

run-once: init-storage
  cd {{function_dir}} && API_KEY='local-dev-key' API_URL='http://localhost:8081/results' STORAGE_CONNECTION_STRING='UseDevelopmentStorage=true' AzureWebJobsStorage='UseDevelopmentStorage=true' python3 -c "import csv, io, os, requests; from datetime import datetime, timezone; from azure.storage.blob import BlobServiceClient; api_url=os.environ['API_URL']; api_key=os.environ['API_KEY']; conn_str=os.environ['STORAGE_CONNECTION_STRING']; container='api-results'; headers={'Authorization': f'Bearer {api_key}', 'User-Agent': 'local-dev-runner/1.0'}; data=requests.get(api_url, headers=headers, timeout=30).json(); output=io.StringIO(); writer=csv.DictWriter(output, fieldnames=data[0].keys()); writer.writeheader(); writer.writerows(data); csv_content=output.getvalue(); blob_name=f'results_{datetime.now(timezone.utc).strftime(\"%Y%m%d_%H%M%S\")}.csv'; blob_service=BlobServiceClient.from_connection_string(conn_str); container_client=blob_service.get_container_client(container); container_client.upload_blob(name=blob_name, data=csv_content, overwrite=True); print(f'Saved {len(data)} records to {container}/{blob_name}')"

run-func: local-up
  cd {{function_dir}} && API_KEY='local-dev-key' API_URL='http://localhost:8081/results' STORAGE_CONNECTION_STRING='UseDevelopmentStorage=true' AzureWebJobsStorage='UseDevelopmentStorage=true' func start --port 7071
